APP_NAME=StationTransfersAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=transfers
DB_USERNAME=transfers
DB_PASSWORD=secret

QUEUE_CONNECTION=sync

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Lock store for ingestion concurrency control (null = use CACHE_STORE).
# In Docker, set to "redis" for cross-process coordination.
TRANSFERS_LOCK_STORE=redis
